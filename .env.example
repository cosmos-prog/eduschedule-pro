# ============================================================
# EduSchedule Pro - Configuration d'environnement
# Copiez ce fichier en .env et modifiez les valeurs
# ============================================================

# --- Base de données MySQL ---
DB_HOST=localhost
DB_NAME=eduschedule_pro
DB_USER=root
DB_PASS=

# --- Sécurité JWT ---
JWT_SECRET=votre_cle_secrete_jwt_ici

# --- QR-Code ---
QR_SECRET=votre_cle_secrete_qr_ici

# --- Application ---
APP_URL=http://localhost:3000
APP_ENV=development

# --- API (pour le frontend React) ---
REACT_APP_API_URL=http://localhost/eduschedule-pro/backend
