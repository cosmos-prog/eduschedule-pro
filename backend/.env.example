# Configuration base de données
DB_HOST=localhost
DB_NAME=eduschedule_pro
DB_USER=root
DB_PASS=

# Clé secrète JWT (changer en production)
JWT_SECRET=eduschedule_jwt_secret_change_me_in_production

# Clé secrète QR-Code (changer en production)
QR_SECRET=eduschedule_qr_secret_change_me_in_production

# URL du frontend (pour les liens dans les QR codes)
APP_URL=http://localhost:3000

# Port frontend (utilisé pour la génération des URLs QR)
FRONT_PORT=3000
