# Apache - EduSchedule Pro Backend
Require all granted

# Passer le header Authorization à PHP (nécessaire sur certains hébergeurs mutualisés)
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# Bloquer l'accès direct aux fichiers de config sensibles
<FilesMatch "\.(env|sql|log|md)$">
    Require all denied
</FilesMatch>
